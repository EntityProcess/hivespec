---
/**
 * Custom 404 page for HiveSpec docs.
 * Self-contained — all styles are scoped inline, matching the site's dark theme and amber accent.
 */
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - Page Not Found | HiveSpec</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="page">
      <div class="card">
        <div class="wordmark">HiveSpec</div>
        <div class="code">404 - PAGE NOT FOUND</div>
        <nav class="links">
          <a href="/">HOME</a>
          <span class="sep"></span>
          <a href="/docs/">DOCS</a>
          <span class="sep"></span>
          <a href="https://github.com/EntityProcess/hivespec" target="_blank" rel="noopener">GITHUB</a>
        </nav>
      </div>
    </div>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #0a0a0f;
        color: #f8fafc;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        min-height: 100vh;
      }

      .page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 1.5rem;
      }

      .card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        padding: 3.5rem 4rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.03);
        max-width: 480px;
        width: 100%;
      }

      .wordmark {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fbbf24;
      }

      .code {
        font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
        font-size: 1.125rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        color: #94a3b8;
      }

      .links {
        display: flex;
        align-items: center;
        gap: 0;
      }

      .links a {
        color: #64748b;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        padding: 0.375rem 1rem;
        transition: color 0.15s ease;
      }

      .links a:hover {
        color: #fbbf24;
      }

      .sep {
        width: 1px;
        height: 14px;
        background: rgba(255, 255, 255, 0.12);
      }

      @media (max-width: 500px) {
        .card {
          padding: 2.5rem 2rem;
        }

        .code {
          font-size: 0.95rem;
        }
      }
    </style>
  </body>
</html>
